root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Markdown uses trailing spaces for hard breaks; don't trim.
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab

[justfile]
indent_style = space
indent_size = 4
